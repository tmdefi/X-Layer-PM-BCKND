PORT=3000
HOST=127.0.0.1
# Railway/production should bind to all interfaces:
# HOST=0.0.0.0

# Supabase Postgres / Prisma
# DATABASE_URL usually uses Supabase's pooled connection string.
# DIRECT_URL usually uses Supabase's direct connection string for migrations.
DATABASE_ENABLED=false
DATABASE_URL=
DIRECT_URL=

# Arc testnet
ARC_CHAIN_ID=5042002
ARC_RPC_URL=https://arc-testnet.drpc.org
ARC_EXPLORER_URL=https://testnet.arcscan.app
ARC_CHAIN_NAME=Arc Testnet
ARC_NATIVE_CURRENCY_NAME=USDC
ARC_NATIVE_CURRENCY_SYMBOL=USDC
ARC_NATIVE_CURRENCY_DECIMALS=18

# Wallet used by backend workers for market creation/resolution.
# Keep this out of source control.
PRIVATE_KEY=
ADMIN_ADDRESS=

# Contracts
USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000
CONDITIONAL_TOKENS_ADDRESS=0x639dbb454025e12093a70e06c89153debf1d88f9
CTF_EXCHANGE_ADDRESS=0x59626881390fbce6d010a5a5693dd64ffb7957a0
MARKET_FACTORY_ADDRESS=0x553a133e1255adbab20b4a0449d0ae7177257f3d
BINARY_MARKET_RESOLVER_ADDRESS=0x6c7e38b06d68a8a62446d2959f91460ac5a21578

# CLOB API security
# Use a long random value. Send it as x-operator-api-key on privileged operator routes.
CLOB_OPERATOR_API_KEY=
# Applied independently to order preparation and signed order submission per client IP.
CLOB_ORDER_RATE_LIMIT_MAX=60
CLOB_ORDER_RATE_LIMIT_WINDOW=1 minute
# Automatically match crossing BUY/SELL orders for the same outcome after signed order submission.
CLOB_AUTO_MATCH_ENABLED=true
CLOB_AUTO_MATCH_MAX_MAKERS=10

# Telegram bot privileged API access
# Use a different secret from CLOB_OPERATOR_API_KEY.
TELEGRAM_BOT_API_KEY=

# Privy server wallets for Telegram users
PRIVY_SERVER_WALLETS_ENABLED=false
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_SIGNER_ID=
PRIVY_WALLET_AUTHORIZATION_PRIVATE_KEY=
PRIVY_WALLET_POLICY_ID=

# Fill unmatched user BUY orders with backend-controlled complementary BUY liquidity.
HOUSE_LIQUIDITY_ENABLED=false
HOUSE_LIQUIDITY_PRIVATE_KEY=
LIQUIDITY_PROVIDER_PRIVATE_KEY=
LIQUIDITY_PROVIDER_ADDRESS=
HOUSE_LIQUIDITY_MAX_ORDER_USDC=100
HOUSE_LIQUIDITY_SPREAD_BPS=0

# API-Football / API-SPORTS
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Optional dev fallback for API plans that cannot access the current season's player stats.
API_FOOTBALL_PLAYER_STATS_SEASON=
# Top leagues are the default featured football competitions for the 2026 focus.
# Add other API-Football league ids here only when they should be synced and market-created too.
API_FOOTBALL_FEATURED_LEAGUE_IDS=39:2026,140:2026,78:2026,135:2026,61:2026,2:2026
# When FOOTBALL_MATCH_PROVIDER=football-data, API-Football is still used for friendly fixtures.
API_FOOTBALL_FRIENDLY_LEAGUE_IDS=10:2026,667:2026
# Football sync can look ahead to top-league fixtures while other providers keep the shorter general sync window.
API_FOOTBALL_SYNC_FIXTURE_DAYS=30

# football-data.org is the preferred football match provider.
FOOTBALL_MATCH_PROVIDER=football-data
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
# Top-league football-data.org competition codes: PL, PD, BL1, SA, FL1.
FOOTBALL_DATA_FEATURED_COMPETITIONS=PL:2026,PD:2026,BL1:2026,SA:2026,FL1:2026
FOOTBALL_DATA_SYNC_FIXTURE_DAYS=120

# CricketData / CricAPI
CRICKET_DATA_API_KEY=
CRICKET_DATA_BASE_URL=https://api.cricapi.com/v1
CRICKET_DATA_SYNC_FIXTURE_DAYS=7
CRICKET_DATA_SYNC_FIXTURE_LIMIT=10

# API-MMA / UFC
# API-Sports keys work across products; API_MMA_KEY falls back to API_FOOTBALL_KEY when blank.
API_MMA_KEY=
API_MMA_BASE_URL=https://v1.mma.api-sports.io
API_MMA_PROMOTION_FILTER=UFC

# PandaScore
PANDASCORE_TOKEN=
PANDASCORE_BASE_URL=https://api.pandascore.co

# Highlightly NBA
HIGHLIGHTLY_API_KEY=
HIGHLIGHTLY_BASE_URL=https://nba.highlightly.net
HIGHLIGHTLY_RAPIDAPI_HOST=
HIGHLIGHTLY_BASKETBALL_LEAGUE=NBA

# Team-level API-Football player candidate cache
PLAYER_CANDIDATE_CACHE_SCHEDULED_SECONDS=21600
PLAYER_CANDIDATE_CACHE_NEAR_KICKOFF_SECONDS=3600
PLAYER_CANDIDATE_CACHE_NEAR_KICKOFF_WINDOW_MINUTES=1440

# Settlement worker
# Max allowed is 60 seconds so markets are checked at least once per minute.
SETTLEMENT_POLL_INTERVAL_SECONDS=60
SETTLEMENT_WORKER_ENABLED=false
SETTLEMENT_SUBMIT_ON_CHAIN=false
# Scheduled fixtures in this window around kickoff get a slower result fallback check.
SETTLEMENT_NEAR_KICKOFF_WINDOW_MINUTES=180
# Set to 0 to disable scheduled-fixture fallback checks.
SETTLEMENT_NEAR_KICKOFF_FALLBACK_INTERVAL_SECONDS=300

# Operator transaction recovery worker
OPERATOR_TX_RECOVERY_WORKER_ENABLED=true
OPERATOR_TX_RECOVERY_POLL_INTERVAL_SECONDS=60
OPERATOR_TX_RECOVERY_LIMIT=100

# Provider sync worker
SYNC_WORKER_ENABLED=true
SYNC_POLL_INTERVAL_SECONDS=300
SYNC_CURRENT_FIXTURE_DAYS=3
SYNC_CREATE_MARKETS_ON_CHAIN=true
# Caps contract writes in one sync run; later runs continue remaining open markets.
SYNC_ON_CHAIN_MARKET_LIMIT=150
# Small delay between on-chain sync RPC operations to avoid public RPC throttling.
SYNC_ON_CHAIN_RPC_DELAY_MS=350
# Concurrency for market-card factory/collateral checks.
MARKET_CARD_RPC_CONCURRENCY=3
